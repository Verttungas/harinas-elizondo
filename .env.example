# ========== Combinado (Docker Compose) ==========
# Copia este archivo a `.env` en la raíz antes de `docker compose up`.
# NUNCA commitees el `.env` con valores reales.

# ---------- Base de datos ----------
DB_USER=fhesa
DB_PASSWORD=change_me_use_a_strong_password
DB_NAME=fhesa

# ---------- Backend ----------
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://fhesa:change_me_use_a_strong_password@database:5432/fhesa?schema=public
CORS_ORIGIN=http://localhost:5173
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=certificados@fhesa.mx
SMTP_FROM_NAME=Certificados FHESA
PDF_STORAGE_PATH=/app/certificados-pdf
APP_BASE_URL=http://localhost:5173
WAREHOUSE_EMAIL=almacen@fhesa.mx

# JWT: debe ser una cadena aleatoria de al menos 32 caracteres.
# Generar con: openssl rand -base64 48
JWT_SECRET=change_me_use_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=8h

# Auth
BCRYPT_COST=10

# Logging: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# Rate limiting (peticiones por minuto por IP)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# ---------- Frontend ----------
VITE_API_BASE_URL=http://localhost:3000/api/v1
