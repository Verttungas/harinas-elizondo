# ========== Backend ==========
NODE_ENV=development
PORT=3000

# PostgreSQL
DATABASE_URL=postgresql://fhesa:fhesa@database:5432/fhesa?schema=public

# CORS (origen del frontend)
CORS_ORIGIN=http://localhost:5173

# SMTP (MailHog en desarrollo)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=certificados@fhesa.mx
SMTP_FROM_NAME=Certificados FHESA

# Almacenamiento de PDFs
PDF_STORAGE_PATH=/app/certificados-pdf

# URL pública del sistema (para links en correos)
APP_BASE_URL=http://localhost:5173

# Correo del almacén (destinatario adicional de certificados)
WAREHOUSE_EMAIL=almacen@fhesa.mx

# JWT
JWT_SECRET=change_me_use_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=8h

# Auth
BCRYPT_COST=10

# Logging
LOG_LEVEL=info
