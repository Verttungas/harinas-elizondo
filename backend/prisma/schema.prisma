// Esquema Prisma mínimo para la Fase A.
// El modelo HealthCheck se eliminará al comenzar la Fase B (modelo de datos real).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model HealthCheck {
  id        BigInt   @id @default(autoincrement())
  createdAt DateTime @default(now())

  @@map("health_checks")
}
